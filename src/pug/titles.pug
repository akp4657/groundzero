extends layouts/base

append variables
    - pageTitle = 'Title history | Ground Zero Wrestling'
    - pageDescription = 'Complete championship lineage for Ground Zero Wrestling titles.'
    - activeNav = 'titles'

block content
    header.gz-page-header
        .container.px-4.px-lg-5
            h1.display-5 Title History
            p.lead.mb-0 Full title lineage for Ground Zero

    section.page-section
        .container.px-4.px-lg-5
            each championship in siteData.titles.lineage
                h2.h4= championship.title
                .table-responsive.mb-5
                    table.table.table-sm.table-bordered
                        thead.table-light
                            tr
                                th(scope='col') #
                                th(scope='col')= championship.holdersLabel
                                th(scope='col') Won
                                th(scope='col') Lost
                                th(scope='col') Days
                        tbody
                            each reign in championship.reigns
                                - const reignDays = getReignDays(reign.won, reign.lost)
                                - const isCurrentReign = String(reign.lost || '').toLowerCase() === 'present'
                                tr
                                    td= reign.number
                                    td= reign.holders
                                    td= reign.won
                                    td= reign.lost
                                    td= reignDays === '—' ? reignDays : `${reignDays}${isCurrentReign ? '+' : ''}`
