extends layouts/base

append variables
    - pageTitle = 'School | Ground Zero Wrestling'
    - pageDescription = 'Train at Rochester’s premier pro wrestling school with coaches from major promotions worldwide.'
    - activeNav = 'school'

block content
    header.gz-page-header
        .container.px-4.px-lg-5
            h1.display-5 School
            p.lead.mb-0 Fully equipped facility, structured classes, and coaches invested in your growth

    section.page-section
        .container.px-4.px-lg-5
            .text-center.mb-4.mb-md-5
                img.gz-respect-the-craft-logo(
                    src='assets/img/brand/respect-the-craft.png',
                    alt='Respect the Craft'
                )
            .row.justify-content-center.mb-5
                .col-lg-10
                    .gz-school-text-panel
                        h2.h3 Welcome to GROUND ZERO
                        p.text-muted.mb-3
                            | A fully equppied training facility dedicated to helping new and experienced students train to become professional wrestlers.
                            | At GROUND ZERO, you will learn from a team of coaches with experience in nearly every notable wrestling promotion in the country as 
                            | well as promotions in Europe and Japan, giving you the skills, knowledge, and ethics you need to build yourself into the best professional wrestler you can be.
                        p.text-muted.mb-0
                            | At GROUND ZERO, wrestling comes first. Respect the Craft. There is no room for ego in this gym. Here, you will learn the art of professional wrestling
                            | and the importance of tradition while embracing the ever-expanding culture of the sport.

            .row.justify-content-center.mb-5
                .col-lg-10
                    .gz-school-text-panel.p-0.overflow-hidden
                        img.w-100(src='assets/img/coaches/GZ_School.jpg', alt='Ground Zero School training promotion')

            .row.gy-5

                .col-12
                    article#coach-colin.mb-5(aria-labelledby='coach-colin-heading')
                        .row.align-items-stretch.gy-3
                            .col-md-4.col-lg-3
                                .gz-coach-card.gz-roster-card.text-dark.h-100
                                    .gz-roster-media
                                        img(src='assets/img/coaches/Colin_Delaney.jpg', alt='', aria-hidden='true')
                                    .p-3
                                        h3#coach-colin-heading.h5.mb-0 Colin Delaney
                            .col-md-8.col-lg-9.d-flex.align-items-stretch
                                .coach-bio.gz-school-text-panel.flex-grow-1.d-flex.flex-column
                                    p.text-muted.mb-0.flex-grow-1
                                        | Best known for wrestling for WWE. He has also wrestled for promotions such as 2CW Squared Circle Wrestling, Chikara, NWA Upstate, Pier 6 Wrestling, 
                                        | Buffalo Championship Wrestling, NWA Empire, LakeShore Wrestling, UWA Hardcore Wrestling, Roc City Wrestling, and CZW. Colin brings a wealth of
                                        | experience and knowledge to the school. Helping students learn what it truly takes to make it to the highest levels of the sport.

                    article#coach-mattick.mb-5(aria-labelledby='coach-mattick-heading')
                        .row.align-items-stretch.gy-3
                            .col-md-4.col-lg-3
                                .gz-coach-card.gz-roster-card.text-dark.h-100
                                    .gz-roster-media
                                        img(src='assets/img/coaches/Mattick.png', alt='', aria-hidden='true')
                                    .p-3
                                        h3#coach-mattick-heading.h5.mb-0 Mattick
                            .col-md-8.col-lg-9.d-flex.align-items-stretch
                                .coach-bio.gz-school-text-panel.flex-grow-1.d-flex.flex-column
                                    p.text-muted.mb-0.flex-grow-1
                                        | Mattick has trained Rochester students for five years with a focus on fundamentals, work ethic,
                                        |  and the belief that consistent reps build confident performers.

                    article#coach-nick.mb-5(aria-labelledby='coach-nick-heading')
                        .row.align-items-stretch.gy-3
                            .col-md-4.col-lg-3
                                .gz-coach-card.gz-roster-card.text-dark.h-100
                                    .gz-roster-media
                                        img(src='assets/img/coaches/nickando.png', alt='', aria-hidden='true')
                                    .p-3
                                        h3#coach-nick-heading.h5.mb-0 Nick Ando
                            .col-md-8.col-lg-9.d-flex.align-items-stretch
                                .coach-bio.gz-school-text-panel.flex-grow-1.d-flex.flex-column
                                    p.text-muted.mb-0.flex-grow-1
                                        | Former 2CW heavyweight champion with titles across New York, Nick emphasizes technical detail,
                                        |  pacing, and the small moments that separate good matches from great ones.

                    article#coach-krist.mb-5(aria-labelledby='coach-krist-heading')
                        .row.align-items-stretch.gy-3
                            .col-md-4.col-lg-3
                                .gz-coach-card.gz-roster-card.text-dark.h-100
                                    .gz-roster-media
                                        img(src='assets/img/coaches/kristworthless.png', alt='', aria-hidden='true')
                                    .p-3
                                        h3#coach-krist-heading.h5.mb-0 Krist XW
                            .col-md-8.col-lg-9.d-flex.align-items-stretch
                                .coach-bio.gz-school-text-panel.flex-grow-1.d-flex.flex-column
                                    p.text-muted.mb-0.flex-grow-1
                                        | Krist trained under Tim Thatcher, Toni Storm, and Gunther while overseas, bringing strict dojo-style
                                        |  habits plus deep knowledge of production and backstage workflows.

                    article#coach-cloudy.mb-5(aria-labelledby='coach-cloudy-heading')
                        .row.align-items-stretch.gy-3
                            .col-md-4.col-lg-3
                                .gz-coach-card.gz-roster-card.text-dark.h-100
                                    .gz-roster-media
                                        img(src='assets/img/coaches/cloudy.png', alt='', aria-hidden='true')
                                    .p-3
                                        h3#coach-cloudy-heading.h5.mb-0 Cloudy
                            .col-md-8.col-lg-9.d-flex.align-items-stretch
                                .coach-bio.gz-school-text-panel.flex-grow-1.d-flex.flex-column
                                    p.text-muted.mb-0.flex-grow-1
                                        | A veteran of CZW, Ring of Honor, Chikara, Dragon Gate USA, IWA-MS, IWS, UWA, 2CW, and more,
                                        |  Cloudy has shared the ring with international stars and stresses adaptable, hard-hitting storytelling.

                    article#coach-cheech.mb-5(aria-labelledby='coach-cheech-heading')
                        .row.align-items-stretch.gy-3
                            .col-md-4.col-lg-3
                                .gz-coach-card.gz-roster-card.text-dark.h-100
                                    .gz-roster-media
                                        img(src='assets/img/coaches/cheech.png', alt='', aria-hidden='true')
                                    .p-3
                                        h3#coach-cheech-heading.h5.mb-0 Cheech
                            .col-md-8.col-lg-9.d-flex.align-items-stretch
                                .coach-bio.gz-school-text-panel.flex-grow-1.d-flex.flex-column
                                    p.text-muted.mb-0.flex-grow-1
                                        | Cheech supports classes with a focus on in-ring presence, humor as a weapon, and helping students
                                        |  find authentic characters that connect with crowds.

                    #seminars-at-ground-zero.mt-5.pt-4(aria-labelledby='seminars-heading')
                        .gz-school-text-panel.mb-4
                            h2#seminars-heading.h3.mb-3 Seminars
                            p.text-muted.mb-0
                                | Guest coaches and special-topic seminars expand what you see in weekly class. The grid below pulls from
                                |  site data—replace names, photos, years, and notes with your real seminar archive.

                        if siteData.seminarGuests && siteData.seminarGuests.length
                            .row.row-cols-1.row-cols-md-2.row-cols-lg-3.g-4
                                each guest, guestIdx in siteData.seminarGuests
                                    -
                                        const seminarImg = guest.image || 'assets/img/roster/placeholder.svg'
                                        const seminarTag = guest.date || ''
                                        const seminarDetail = guest.note || ''
                                    .col.h-100
                                        button.gz-seminar-card-trigger(
                                            type='button',
                                            data-seminar-index=guestIdx,
                                            aria-haspopup='dialog',
                                            aria-controls='gzSeminarModal',
                                            aria-label=`Open seminar photos: ${guest.name}`
                                        )
                                            span.gz-seminar-card-trigger-inner.d-block
                                                .gz-coach-card.gz-roster-card.text-start.h-100
                                                    .gz-roster-media
                                                        img(src=seminarImg, alt='', decoding='async')
                                                    .p-3
                                                        h2.h5= guest.name
                                                        if seminarTag
                                                            p.small.text-muted.mb-2= seminarTag
                                                        if seminarDetail
                                                            p.small.mb-0= seminarDetail

                            #gzSeminarModal.modal.fade(
                                tabindex='-1',
                                aria-labelledby='gzSeminarModalLabel',
                                aria-hidden='true'
                            )
                                .modal-dialog.modal-lg.modal-dialog-centered.modal-dialog-scrollable
                                    .modal-content
                                        .modal-header
                                            h2#gzSeminarModalLabel.modal-title.h5
                                            button.btn-close(
                                                type='button',
                                                data-bs-dismiss='modal',
                                                aria-label='Close'
                                            )
                                        .modal-body.p-0
                                            #gzSeminarCarousel.carousel.slide(data-bs-ride='false')
                                                .carousel-inner
                                                button.carousel-control-prev(
                                                    type='button',
                                                    data-bs-target='#gzSeminarCarousel',
                                                    data-bs-slide='prev',
                                                    aria-label='Previous image'
                                                )
                                                    span.carousel-control-prev-icon(aria-hidden='true')
                                                button.carousel-control-next(
                                                    type='button',
                                                    data-bs-target='#gzSeminarCarousel',
                                                    data-bs-slide='next',
                                                    aria-label='Next image'
                                                )
                                                    span.carousel-control-next-icon(aria-hidden='true')

                            script#gz-seminar-guests-data(type='application/json')!= JSON.stringify(siteData.seminarGuests || [])