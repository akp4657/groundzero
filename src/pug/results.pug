extends layouts/base

append variables
    - pageTitle = 'Results | Ground Zero Wrestling'
    - pageDescription = 'Match results and highlights from recent Ground Zero events.'
    - activeNav = 'results'

block content
    header.gz-page-header
        .container.px-4.px-lg-5
            h1.display-5 Results
            p.lead.mb-0 Official outcomes from the latest Ground Zero event

    section.page-section
        .container.px-4.px-lg-5
            - const latestResults = siteData.results[0]
            if latestResults
                h2.h3.mb-2 Ground Zero #{latestResults.event}
                p.text-muted.mb-4 #{latestResults.date} — full card results.

                .table-responsive.mb-5
                    table.table.table-striped.table-bordered.align-middle
                        thead.table-dark
                            tr
                                th(scope='col') Match
                                th(scope='col') Result
                                th(scope='col') Notes
                        tbody
                            each m in latestResults.matches
                                tr
                                    td= m.match
                                    td= m.result
                                    td= m.notes || '—'

            if siteData.results.length > 1
                h2.h4.mb-3 Previous events
                each past in siteData.results.slice(1)
                    h3.h5.mt-4.mb-2 Ground Zero #{past.event}
                    p.small.text-muted.mb-3 #{past.date}
                    .table-responsive.mb-4
                        table.table.table-sm.table-bordered.align-middle
                            thead.table-light
                                tr
                                    th(scope='col') Match
                                    th(scope='col') Result
                                    th(scope='col') Notes
                            tbody
                                each m in past.matches
                                    tr
                                        td= m.match
                                        td= m.result
                                        td= m.notes || '—'