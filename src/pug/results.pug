extends layouts/base

append variables
    - pageTitle = 'Results | Ground Zero Wrestling'
    - pageDescription = 'Match results and highlights from recent Ground Zero events.'
    - activeNav = 'results'

block content
    header.gz-page-header
        .container.px-4.px-lg-5
            h1.display-5 Results
            p.lead.mb-0 Official outcomes from the last two Ground Zero events

    section.page-section
        .container.px-4.px-lg-5
            - const recentResults = (siteData.results || []).slice(0, 2)
            each show, idx in recentResults
                h2.h3.mb-2(class=idx > 0 ? 'mt-5 pt-2' : '') Ground Zero #{show.event}
                p.text-muted.mb-4 #{show.date} — full card results.

                .table-responsive(class=idx === recentResults.length - 1 ? 'mb-0' : 'mb-5')
                    table.table.table-striped.table-bordered.align-middle
                        thead.table-dark
                            tr
                                th(scope='col') Match
                                th(scope='col') Result
                                th(scope='col') Notes
                        tbody
                            each m in show.matches
                                tr
                                    td= m.match
                                    td= m.result
                                    td= m.notes || '—'

            if !recentResults.length
                p.text-muted.mb-0 No results published yet.
