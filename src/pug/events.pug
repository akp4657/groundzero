extends layouts/base

append variables
    - pageTitle = 'Events & Tickets | Ground Zero Wrestling'
    - pageDescription = 'Upcoming Ground Zero shows, ticket links, and how to support the brand.'
    - activeNav = 'events'

block content
    header.gz-page-header
        .container.px-4.px-lg-5
            h1.display-5 Events &amp; Tickets
            p.lead.mb-0 Upcoming Ground Zero shows, ticket links, and how to support the brand

    section.page-section
        .container.px-4.px-lg-5
            .row.g-4.g-lg-5#gz-events-cards
                .col-md-6.d-flex
                    .card.gz-event-card.h-100.w-100
                        .gz-event-card__media.gz-event-card__media--poster
                            img(src='assets/img/events/Chapter9.jpg', alt='Ground Zero Chapter 10 event poster')
                        .gz-event-card__body-push.flex-grow-1
                        .card-body.d-flex.flex-column.pt-4
                            h2.h4.gz-event-card__title.mb-0 Ground Zero - Chapter 10
                            p.text-muted.gz-event-card__lede.mb-0 May 17th, 2026 at Aerial Arts of Rochester
                            a.btn.btn-primary.mt-auto(href='https://groundzeroshop.bigcartel.com/category/tickets', rel='noopener noreferrer', target='_blank') Buy Tickets
                .col-md-6.d-flex
                    .card.gz-event-card.h-100.w-100
                        .gz-event-card__media.gz-event-card__media--contain
                            img(src='assets/img/events/shop.png', alt='Ground Zero shop and merch')
                        .gz-event-card__body-push.flex-grow-1
                        .card-body.d-flex.flex-column.pt-4
                            h2.h4.gz-event-card__title.mb-0 Merch &amp; Ticket Bundles
                            p.text-muted.gz-event-card__lede.mb-0
                                | Grab show tickets, apparel, and limited drops directly from the Ground Zero shop between events.
                            a.btn.btn-primary.mt-auto(href='https://groundzeroshop.bigcartel.com/', rel='noopener noreferrer', target='_blank') Visit the Shop

            .row.justify-content-center.mt-5
                .col-lg-8.text-center
                    p.text-muted.small
                        | Event lineups rotate—follow social channels for on-sale announcements and last-minute additions.
