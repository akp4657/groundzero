extends layouts/base

append variables
    - pageTitle = 'Ground Zero Wrestling | Rochester, NY'
    - pageDescription = 'Premier professional wrestling training, live events, results, roster, and championships in Rochester, NY.'
    - activeNav = 'home'

block content
    header.masthead
        .container.px-4.px-lg-5.h-100
            .row.gx-4.gx-lg-5.h-100.align-items-center.justify-content-center.text-center
                .col-lg-8.align-self-end
                    h1.text-white.font-weight-bold This is Ground Zero
                    hr.divider
                .col-lg-8.align-self-baseline
                    p.text-white-75.mb-4
                        | Rochester, NY’s home for professional wrestling training and live events. Scroll for highlights
                        |  or use the menu for full pages.
                    .d-flex.flex-column.flex-sm-row.gap-3.justify-content-center
                        a.btn.btn-primary.btn-xl(href='#events') Events &amp; tickets
                        a.btn.btn-light.btn-xl(href='school.html') Train with us

    section#events.page-section
        .container.px-4.px-lg-5
            .row.justify-content-center
                .col-lg-10.text-center
                    h2.mt-0 Events &amp; tickets
                    hr.divider
                    p.text-muted.mb-4
                        | Upcoming Ground Zero shows, ticket links, and how to catch the action live.
                    p.text-muted.mb-4.small
                        | Shop merch and tickets at the Ground Zero store, plus featured Eventbrite listings when shows go live.
                    a.btn.btn-primary.btn-xl(href='events.html') Show more

    section#school.page-section.bg-primary
        .container.px-4.px-lg-5
            .row.justify-content-center
                .col-lg-10.text-center
                    h2.text-white.mt-0 School
                    hr.divider.divider-light
                    p.text-white-75.mb-4
                        | Fully equipped training facility with coaches who have worked across major promotions. New and experienced
                        |  students build fundamentals, character, and match psychology.
                    a.btn.btn-light.btn-xl(href='school.html') Show more

    section#results.page-section
        .container.px-4.px-lg-5
            .row.justify-content-center
                .col-lg-10.text-center
                    h2.mt-0 Results
                    hr.divider
                    p.text-muted.mb-4
                        | Latest match outcomes from Ground Zero events—winners, stipulations, and quick notes.
                    .table-responsive.text-start.mb-4
                        table.table.table-sm.table-bordered.mb-0
                            thead.table-light
                                tr
                                    th(scope='col') Event
                                    th(scope='col') Match
                                    th(scope='col') Result
                            tbody
                                tr
                                    td Ground Zero Chapter 4
                                    td Tag team showcase
                                    td The Runaways def. Midnight Shift
                                tr
                                    td Ground Zero Chapter 3
                                    td Singles
                                    td Ava Stone def. Chris Kade
                    a.btn.btn-primary.btn-xl(href='results.html') Show more

    section#roster.page-section.bg-dark.text-white
        .container.px-4.px-lg-5
            .row.justify-content-center
                .col-lg-10.text-center
                    h2.mt-0 Roster
                    hr.divider.divider-light
                    p.text-white-75.mb-4
                        | Meet the athletes representing Ground Zero—homegrown talent and visiting competitors.
                    .row.g-3.text-start.mb-4
                        .col-md-4
                            .gz-coach-card.text-dark
                                img(src='assets/img/roster/placeholder.svg', alt='')
                                .p-3
                                    h3.h5.mb-1 Ava Stone
                                    p.small.text-muted.mb-0 “The Quarry” — technical striker.
                        .col-md-4
                            .gz-coach-card.text-dark
                                img(src='assets/img/roster/placeholder.svg', alt='')
                                .p-3
                                    h3.h5.mb-1 Chris Kade
                                    p.small.text-muted.mb-0 High-flyer out of Rochester.
                        .col-md-4
                            .gz-coach-card.text-dark
                                img(src='assets/img/roster/placeholder.svg', alt='')
                                .p-3
                                    h3.h5.mb-1 The Runaways
                                    p.small.text-muted.mb-0 Tag team — chaos and heart.
                    a.btn.btn-light.btn-xl(href='roster.html') Show more

    section#title-history.page-section
        .container.px-4.px-lg-5
            .row.justify-content-center
                .col-lg-10.text-center
                    h2.mt-0 Title history
                    hr.divider
                    p.text-muted.mb-4 Current champions across Ground Zero championships.
                    .table-responsive.text-start.mb-4
                        table.table.table-sm.table-bordered.mb-0
                            thead.table-light
                                tr
                                    th(scope='col') Championship
                                    th(scope='col') Champion(s)
                                    th(scope='col') Since
                            tbody
                                tr
                                    td Ground Zero Heavyweight
                                    td Jordan Blake
                                    td March 2026
                                tr
                                    td Ground Zero Tag Team
                                    td The Runaways
                                    td February 2026
                                tr
                                    td Ground Zero Women’s
                                    td Ava Stone
                                    td January 2026
                    a.btn.btn-primary.btn-xl(href='titles.html') Show more
